#!/bin/bash

# The file containing the commit message
COMMIT_MSG_FILE=$1

# Get the current branch name
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

# Extract the ClickUp Task ID using regex (looks for 'CU-' followed by alphanumeric characters, case-insensitive)
CLICKUP_ID=$(echo "$BRANCH_NAME" | grep -o -i -E 'CU-[a-zA-Z0-9]+' | head -n 1)

# If no ClickUp ID is found in the branch name, exit and let the commit proceed normally
if [ -z "$CLICKUP_ID" ]; then
    exit 0
fi

# Convert the ID to uppercase for consistency (e.g., cu-123ab -> CU-123AB)
CLICKUP_ID=$(echo "$CLICKUP_ID" | tr '[:lower:]' '[:upper:]')

# Check if the commit message already contains the ID to avoid duplicates
if grep -q -i "$CLICKUP_ID" "$COMMIT_MSG_FILE"; then
    exit 0
fi

# Append the ClickUp ID to the end of the first line of the commit message
# Mac/BSD sed requires a backup extension (like .bak), which we immediately remove
sed -i.bak -e "1s/$/ (#$CLICKUP_ID)/" "$COMMIT_MSG_FILE"
rm -f "${COMMIT_MSG_FILE}.bak"

exit 0